# Cube centered at origin, extents -1 to 1
# Triangulated, with normals and UVs (0-1 range)

o Cube

# Vertices
v -1 -1 -1
v  1 -1 -1
v  1  1 -1
v -1  1 -1
v -1 -1  1
v  1 -1  1
v  1  1  1
v -1  1  1

# UVs (shared layout per face)
vt 0 0
vt 1 0
vt 1 1
vt 0 1

# Normals
vn  0  0 -1
vn  0  0  1
vn -1  0  0
vn  1  0  0
vn  0 -1  0
vn  0  1  0

# Faces (triangulated)

# Front (-Z)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# Back (+Z)
f 6/2/2 5/1/2 8/4/2
f 6/2/2 8/4/2 7/3/2

# Left (-X)
f 5/1/3 1/2/3 4/3/3
f 5/1/3 4/3/3 8/4/3

# Right (+X)
f 2/1/4 6/2/4 7/3/4
f 2/1/4 7/3/4 3/4/4

# Bottom (-Y)
f 5/1/5 6/2/5 2/3/5
f 5/1/5 2/3/5 1/4/5

# Top (+Y)
f 4/1/6 3/2/6 7/3/6
f 4/1/6 7/3/6 8/4/6