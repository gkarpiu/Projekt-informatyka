# Room with inward facing walls + center block
# Triangulated
# Includes normals and 0-1 UVs

o Room

############################
# VERTICES
############################

# Floor
v 0 0 0
v 10 0 0
v 10 0 10
v 0 0 10

# Wall top
v 0 5 0
v 10 5 0
v 10 5 10
v 0 5 10

# Block bottom
v 4 0 4
v 6 0 4
v 6 0 6
v 4 0 6

# Block top
v 4 2 4
v 6 2 4
v 6 2 6
v 4 2 6

############################
# NORMALS
############################

# Room
vn 0 1 0        # Floor (up)
vn 0 0 1        # Wall Z-
vn -1 0 0       # Wall X+
vn 0 0 -1       # Wall Z+
vn 1 0 0        # Wall X-

# Block
vn 0 -1 0       # Bottom
vn 0 1 0        # Top
vn 0 0 -1       # Front
vn 1 0 0        # Right
vn 0 0 1        # Back
vn -1 0 0       # Left

############################
# UVs (0-1 per surface)
############################

# Generic quad UVs
vt 0 0
vt 1 0
vt 1 1
vt 0 1

############################
# FACES
############################

# Floor (uses normal 1)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# Wall Z=0 (normal 2)
f 1/1/2 6/3/2 2/2/2
f 1/1/2 5/4/2 6/3/2

# Wall X=10 (normal 3)
f 2/1/3 7/3/3 3/2/3
f 2/1/3 6/4/3 7/3/3

# Wall Z=10 (normal 4)
f 3/1/4 8/3/4 4/2/4
f 3/1/4 7/4/4 8/3/4

# Wall X=0 (normal 5)
f 4/1/5 5/3/5 1/2/5
f 4/1/5 8/4/5 5/3/5

o CenterBlock

# Bottom (normal 6)
f 9/1/6 11/3/6 10/2/6
f 9/1/6 12/4/6 11/3/6

# Top (normal 7)
f 13/1/7 14/2/7 15/3/7
f 13/1/7 15/3/7 16/4/7

# Front (normal 8)
f 9/1/8 10/2/8 14/3/8
f 9/1/8 14/3/8 13/4/8

# Right (normal 9)
f 10/1/9 11/2/9 15/3/9
f 10/1/9 15/3/9 14/4/9

# Back (normal 10)
f 11/1/10 12/2/10 16/3/10
f 11/1/10 16/3/10 15/4/10

# Left (normal 11)
f 12/1/11 9/2/11 13/3/11
f 12/1/11 13/3/11 16/4/11